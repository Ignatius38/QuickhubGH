# ============================================
# QuickHubGH Platform Environment Variables
# ============================================

# Supabase Configuration
# Get these from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Keep this secure!

# Google OAuth Configuration
# Note: Google OAuth client ID/secret are configured directly in Supabase Dashboard
# No environment variables needed here
# Follow docs/supabase-google-oauth-setup.md for setup instructions

# Paystack Configuration
# Get these from Paystack Dashboard → Settings → API Keys & Webhooks
PAYSTACK_SECRET_KEY=sk_live_...  # Live secret key
PAYSTACK_PUBLIC_KEY=pk_live_...   # Live public key

# For development/testing, use test keys:
# PAYSTACK_SECRET_KEY=sk_test_...
# PAYSTACK_PUBLIC_KEY=pk_test_...

# Application URL
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Payment Test Mode
# Set to true to bypass Paystack API during development
PAYMENT_TEST_MODE=false

# Node Environment
NODE_ENV=development

# ============================================
# Configuration Notes
# ============================================

# 1. Supabase Setup:
#    - Create project at https://supabase.com
#    - Get credentials from Settings → API
#    - Configure Google OAuth in Authentication → Providers

# 2. Google OAuth Setup:
#    - Create Google Cloud Console project
#    - Configure OAuth consent screen
#    - Create OAuth 2.0 credentials
#    - Add redirect URIs:
#      - http://localhost:3000/auth/callback
#      - https://your-project-id.supabase.co/auth/v1/callback

# 3. Paystack Setup:
#    - Create account at https://paystack.com
#    - Generate API keys in Dashboard
#    - Configure webhook: https://your-domain.com/api/webhooks/paystack

# 4. Local Development:
#    - Copy this file to .env.local
#    - Fill in actual values
#    - Run: npm run dev